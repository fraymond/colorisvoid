// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StoryStatus {
  DRAFT
  PUBLISHED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]
  stories  Story[]  @relation("StoryAuthor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Story {
  id          String      @id @default(cuid())
  publicId    String?     @unique
  slug        String      @unique
  title       String
  body        String
  status      StoryStatus @default(DRAFT)
  publishedAt DateTime?

  authorEmail       String?
  authorDisplayName String?

  authorId String
  author   User @relation("StoryAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([authorId])
}

model ChatQuestion {
  id        String   @id @default(cuid())
  question  String
  response  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model NewsItem {
  id          String   @id @default(cuid())
  sourceUrl   String   @unique
  title       String
  summary     String?
  sourceName  String
  publishedAt DateTime
  fetchedAt   DateTime @default(now())

  @@index([publishedAt])
}

model NewsDigest {
  id        String   @id @default(cuid())
  date      DateTime @unique
  title     String?
  hashtags  String[] @default([])
  script    String
  pickedIds String[]
  createdAt DateTime @default(now())

  feedbacks      NewsDigestFeedback[]
  generationMeta NewsDigestGenerationMeta?
}

enum NewsDigestStyleRuleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model NewsDigestFeedback {
  id             String   @id @default(cuid())
  digestId       String
  createdBy      String
  scoreOverall   Int
  scoreHumor     Int
  scoreHumanity  Int
  scoreClarity   Int
  scoreInsight   Int
  bestLine       String
  worstIssue     String
  rewriteHint    String?
  comment        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  digest NewsDigest @relation(fields: [digestId], references: [id], onDelete: Cascade)

  @@unique([digestId, createdBy])
  @@index([digestId, createdAt])
  @@index([createdBy, createdAt])
}

model NewsDigestStyleRuleSet {
  id                  String                    @id @default(cuid())
  version             Int                       @unique
  status              NewsDigestStyleRuleStatus @default(DRAFT)
  title               String
  sourceSummary       String
  sourceFeedbackCount Int                       @default(0)
  model               String?
  moreToLeanInto      String[]
  lessToAvoid         String[]
  guardrails          String[]
  exampleWins         String[]
  exampleMisses       String[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  approvedAt          DateTime?
  approvedBy          String?

  generations NewsDigestGenerationMeta[]

  @@index([status, createdAt])
}

model NewsDigestGenerationMeta {
  id                    String   @id @default(cuid())
  digestId              String   @unique
  model                 String
  basePromptVersion     String
  ruleSetId             String?
  ruleSetVersion        Int?
  feedbackWindowSummary String?
  createdAt             DateTime @default(now())

  digest  NewsDigest              @relation(fields: [digestId], references: [id], onDelete: Cascade)
  ruleSet NewsDigestStyleRuleSet? @relation(fields: [ruleSetId], references: [id], onDelete: SetNull)

  @@index([ruleSetId, createdAt])
}
